# AWS S3 Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
S3_BUCKET_NAME=your_bucket_name_here
S3_REGION=us-east-1
S3_ENDPOINT=https://s3.amazonaws.com

# Server Configuration
PORT=5000

# Database Configuration (Development)
# Use DEV_DATABASE_URL for local/dev database (takes priority over DATABASE_URL)
DEV_DATABASE_URL=postgresql://user:password@host:5432/dev_confirmations
DATABASE_SSL=false

# Database Configuration (Production - use on Render)
# On production, only set DATABASE_URL (DEV_DATABASE_URL should not be set)
DATABASE_URL=postgresql://user:password@host:5432/database
DATABASE_SSL=true

# Authentication
JWT_SECRET=your-random-32-char-secret-key-here
JWT_EXPIRES_IN=24h

# PIX Configuration
PIX_KEY=your-pix-key-here
PIX_MERCHANT_NAME=Your Name
PIX_MERCHANT_CITY=Your City
